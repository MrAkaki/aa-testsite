# =============================================================================
# Template environment file. Copy it to `.env` and fill in real values:
#     PowerShell:  Copy-Item .env.example .env
#     Bash:        cp .env.example .env
# `.env` is gitignored and must NEVER be committed (it holds your secret key).
# =============================================================================

# --- Site URL pieces ---------------------------------------------------------
# (conf/local.py overrides SITE_URL to http://localhost for this local test box)
PROTOCOL=http://
AUTH_SUBDOMAIN=auth
DOMAIN=localhost

# --- AA container image (pin to the Alliance Auth release you want) ----------
AA_DOCKER_TAG=registry.gitlab.com/allianceauth/allianceauth/auth:v5.1.4

# --- Debug -------------------------------------------------------------------
# AA treats ANY value (even "False") as truthy. DELETE this line for debug OFF.
AA_DEBUG=True

# --- Site identity -----------------------------------------------------------
AA_SITENAME="AA Test"

# --- Django secret key -------------------------------------------------------
# REQUIRED. Generate a fresh random value, e.g.:  openssl rand -hex 24
AA_SECRET_KEY=CHANGE_ME__run: openssl rand -hex 24

# --- Redis (Celery broker + Django cache; compose service name) --------------
AA_REDIS=redis:6379

# --- EVE Online ESI application ----------------------------------------------
# Create at https://developers.eveonline.com  (callback: http://localhost/sso/callback)
ESI_SSO_CLIENT_ID=your-eve-client-id
ESI_SSO_CLIENT_SECRET=your-eve-client-secret
ESI_USER_CONTACT_EMAIL=you@example.com

# --- Discord application (AA Discord service + aadiscordbot) ------------------
# Create at https://discord.com/developers/applications
#   OAuth2 redirect URL: http://localhost/discord/callback/
#   Enable all 3 Privileged Gateway Intents (Presence, Server Members, Message Content).
# DISCORD_BOT_TOKEN must be NON-EMPTY or the app won't boot (a dummy value is fine to
# start without a working bot; replace with the real token to actually connect Discord).
DISCORD_GUILD_ID=your-discord-guild-id
DISCORD_APP_ID=your-discord-app-id
DISCORD_APP_SECRET=your-discord-app-secret
DISCORD_BOT_TOKEN=replace-with-real-bot-token
